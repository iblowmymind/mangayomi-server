{
  "name": "mangayomi-cloudflare",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles.css -o ./public/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/styles.css -o ./public/styles.css --watch",
    "predev": "npm run build:css",
    "predeploy": "npm run build:css",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "migrations:local": "wrangler d1 execute DB --local --file=migrations/schema.sql",
    "migrations:remote": "wrangler d1 execute DB --remote --file=migrations/schema.sql"
  },
  "dependencies": {
    "hash-wasm": "^4.12.0",
    "hono": "^4.7.11"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250529.0",
    "autoprefixer": "^10.4.20",
    "daisyui": "^4.12.14",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "wrangler": "^4.97.0"
  },
  "allowScripts": {
    "esbuild@0.27.3": true,
    "sharp@0.34.5": true,
    "workerd@1.20260601.1": true
  }
}
